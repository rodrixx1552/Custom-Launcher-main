<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- HOT UPDATE LOADER: Fetches latest UI logic from GitHub for instant updates -->
    <script>
        (async () => {
            const REMOTE_URL = 'https://raw.githubusercontent.com/rodrixx1552/Custom-Launcher-main/main/src/js/scripts/appCore.js?t=' + Date.now();
            const LOCAL_JS = '../js/scripts/appCore.js';
            const logOTA = (msg) => console.log('%c[OTA] ' + msg, 'color: #ffb7c5; font-weight: bold;');
            
            try {
                logOTA('Checking for Remote Core (Hot Update)...');
                const response = await fetch(REMOTE_URL);
                if (!response.ok) throw new Error('Remote fetch returned ' + response.status);
                const code = await response.text();
                
                if (code.length < 100) throw new Error('Remote code suspiciously small');
                
                const script = document.createElement('script');
                script.text = code;
                document.head.appendChild(script);
                logOTA('HOT UPDATE APPLIED! Core logic is now LIVE 🚀');
            } catch (e) {
                console.warn('[OTA] Remote fetch failed. Using fallback local core.', e.message);
                const script = document.createElement('script');
                script.src = LOCAL_JS;
                document.head.appendChild(script);
            }
        })();
    </script>
    <script src="../../node_modules/skinview3d/bundles/skinview3d.bundle.js"></script>
    <link rel="stylesheet" href="../../node_modules/@fortawesome/fontawesome-free/css/all.css">
    <link rel="stylesheet" href="../../node_modules/bootstrap/dist/css/bootstrap.css">
    <link rel="stylesheet" href="../css/main.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;900&display=swap" rel="stylesheet">
    
    <title> <%=title%> </title>
</head>
<body>
    <%- include('preloader.ejs') %>
    <div id="bg-anim" class="background-animation" style="opacity: 0;">
        <div class="background-image"></div>
        <div class="clouds"></div>
        <div class="particles"></div>
    </div>
<%- include('frame.ejs')  %> 
    <div id="user-hub" class="glass">
        <div class="user-info">
            <span id="user-name-text">PILOT OFFLINE</span>
            <span class="user-status-dot"></span>
        </div>
        <img id="user-avatar" src="../assets/user.png" alt="Pilot Head">
    </div>
<div id="root">
        
        <div class="app-layout">
            <aside class="sidebar">
                <div class="sidebar-top">
                    <div class="nav-item active" data-tab="play">
                        <i class="fas fa-heart"></i>
                    </div>
                    <div class="nav-item" data-tab="accounts">
                        <i class="fas fa-user-circle"></i>
                    </div>
                </div>
                <nav class="sidebar-nav">
                    <div class="nav-item">
                        <i class="fas fa-play"></i>
                        <span>Play</span>
                    </div>
                    <div class="nav-item">
                        <i class="fas fa-puzzle-piece"></i>
                        <span>Mods</span>
                    </div>
                    <div class="nav-item">
                        <i class="fas fa-cube"></i>
                        <span>Skins</span>
                    </div>
                    <div class="nav-item">
                        <i class="fas fa-cog"></i>
                        <span>Settings</span>
                    </div>
                    <div class="nav-item">
                        <i class="fas fa-users"></i>
                        <span>Community</span>
                    </div>
                </nav>
            </aside>
            <main id="main-content">
                <%- include('main.ejs') %> 
            </main>
        </div>
    </div> 

    <script src="../../node_modules/bootstrap/dist/js/bootstrap.bundle.js"></script>
</body>
</html>