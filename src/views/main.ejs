<div id="mainContainer" style="animation: scaleIn 0.8s ease-out;">
    <div class="top-section" style="margin-bottom: 40px;">
        <div class="logo-wrapper">
            <img src="../assets/los_papus/logo.png" alt="LosPapus Lover" class="main-logo">
        </div>
    </div>

    <div class="middle-section" style="margin-bottom: 60px;">
        <div class="version-card glass" style="text-align: center; padding: 50px; min-width: 450px; border-radius: 30px; position: relative;">
            <div style="position: absolute; top: -15px; left: 50%; transform: translateX(-50%); background: #ffb7c5; color: #000; padding: 5px 20px; border-radius: 10px; font-size: 10px; font-weight: 900; letter-spacing: 2px;">ACTIVE DEPLOYMENT</div>
            
            <h2 style="font-weight: 900; letter-spacing: 8px; color: #ffb7c5; margin-bottom: 10px; text-shadow: 0 0 20px rgba(255,183,197,0.3);">JAVA EDITION</h2>
            <div id="selected-version-text" style="font-size: 28px; font-weight: 900; opacity: 0.9; margin-bottom: 30px; letter-spacing: 1px;">Minecraft 1.20.1</div>
            
            <div class="server-status-pill" style="display: inline-flex; align-items: center; gap: 12px; background: rgba(0,0,0,0.4); padding: 10px 20px; border-radius: 50px; border: 1px solid rgba(255,183,197,0.3); box-shadow: inset 0 0 20px rgba(0,0,0,0.5);">
                <div class="pulse-dot" style="width: 10px; height: 10px; background: #4cd137; border-radius: 50%; box-shadow: 0 0 15px #4cd137; animation: pulse 2s infinite;"></div>
                <span id="server-ping-text" style="font-size: 13px; font-weight: 900; color: #ddd; letter-spacing: 1px;">SERVER ONLINE | 12/100</span>
            </div>
        </div>
    </div>

    <div class="bottom-section">
        <div class="play-area" style="position: relative;">
            <div class="play-glow" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 120%; height: 120%; background: radial-gradient(circle, rgba(255,183,197,0.4) 0%, transparent 70%); z-index: -1; filter: blur(20px); animation: pulseGlow 3s infinite alternate;"></div>
            <button class="btn-play-custom" id="play-btn" style="padding: 30px 140px; font-size: 42px; border-radius: 25px;">PLAY</button>
        </div>

        <div class="user-footer" style="margin-top: 40px;">
            <div class="version-info" style="opacity: 0.6;">
                CORE v1.2.0-STABLE <span style="margin: 0 10px;">|</span> BUILD: 2024.03
            </div>
            <div class="user-display" style="background: rgba(255,183,197,0.1); padding: 8px 20px; border-radius: 12px; border: 1px solid rgba(255,183,197,0.2);">
                <i class="fas fa-crown" style="margin-right: 10px; color: #ffb7c5;"></i>
                <span id="user-name-text" style="color: #fff;">EL_PAPU_ADMIN</span>
            </div>
            <div class="social-icons">
                <a href="#" title="Discord"><i class="fab fa-discord"></i></a>
                <a href="#" title="Store"><i class="fas fa-shopping-cart"></i></a>
                <a href="#" title="Source"><i class="fab fa-github"></i></a>
            </div>
        </div>
    </div>
</div>